---
import { getCollection } from "astro:content";
import BookingForm from "../../../features/booking/components/BookingForm.vue";
import ExcursionLayout from "../../../features/excursions/components/ExcursionLayout.astro";
import { useTranslations } from "../../../i18n/utils";
import Layout from "../../../layouts/Layout.astro";
import { generateExcursionJsonLd } from "../../../lib/structuredData";
import JsonLd from "../../../shared/ui/JsonLd.astro";

const { slug } = Astro.params;
const locale = Astro.currentLocale || "en";

const excursions = await getCollection("excursions");
const excursionEntry = excursions.find(
  (entry) => entry.id.toLowerCase() === (slug || "").toLowerCase(),
);

if (!excursionEntry) {
  Astro.response.status = 404;
  // eslint-disable-next-line unicorn/prefer-module
  return Astro.redirect("/404");
}

const excursion = excursionEntry.data;

const t = useTranslations(locale);
const keyPrefix = `excursion.list.${excursion.i18nKeyPrefix}`;

const title = t(`${keyPrefix}.title`);
const description = t(`${keyPrefix}.description`) + " " + t(`${keyPrefix}.tagline`);

const excursionJsonLd = generateExcursionJsonLd({
  name: excursion.jsonLd.name,
  description: excursion.jsonLd.description,
  provider: "Amsirar Trip",
  image: `https://amsirartrip.com${excursion.image.src}`,
  duration: excursion.duration,
  location: { point: excursion.location },
  url: `https://amsirartrip.com/excursions/${excursionEntry.id}`,
});

const excursionTitleClean = t(`${keyPrefix}.title`);
---

<Layout
  description={description}
  title={title}
>
  <JsonLd
    data={excursionJsonLd}
    id={`${excursion.excursionKey}-jsonld`}
  />
  <ExcursionLayout
    excursionKey={excursion.excursionKey}
    imageSrc={excursion.image}
    locale={locale}
  >
    <BookingForm
      client:visible
      excursionId={String(excursion.bookingId)}
      excursionTitle={excursionTitleClean}
      fullWidth
    />
  </ExcursionLayout>
</Layout>
