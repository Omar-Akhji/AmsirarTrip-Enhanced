---
import { Check, Clock, Hotel, Navigation2, Tent, Utensils } from "lucide-astro";

const getOrdinalSuffix = (number_: number) => {
  const index = number_ % 10;
  const k = number_ % 100;
  if (index === 1 && k !== 11) return number_ + "st";
  if (index === 2 && k !== 12) return number_ + "nd";
  if (index === 3 && k !== 13) return number_ + "rd";
  return number_ + "th";
};

interface ItineraryDay {
  number: number;
  title: string;
  text: string[];
  accommodation?: string;
  meals?: string;
  activities?: string;
  arrival?: string;
}

interface Props {
  days: ItineraryDay[];
  accommodationLabel: string;
  mealsLabel: string;
  activitiesLabel: string;
  arrivalLabel: string;
}

const { days, accommodationLabel, mealsLabel, activitiesLabel, arrivalLabel } = Astro.props;
---

<div class="space-y-8">
  {
    days.map((day, index) => (
      <div
        data-animate="fade-up"
        style={`transition-delay:${index * 100}ms`}
      >
        <div class="group relative">
          <div class="mbe-6">
            <div class="mbe-4 flex items-center gap-4">
              <div class="shrink-0">
                <div class="flex items-center justify-center rounded-full bg-linear-to-br from-orange-500 to-amber-600 px-4 text-lg font-bold text-white shadow-lg transition-shadow duration-300 block-12 group-hover:shadow-xl">
                  {getOrdinalSuffix(day.number)} Day
                </div>
              </div>
            </div>
          </div>

          <div class="relative space-y-3 border-s-0 ps-0 sm:ms-5.5 sm:border-s-2 sm:border-orange-200/50 sm:ps-8">
            <div class="mbe-4 flex flex-wrap items-center gap-2">
              {day.title.split("➜").map((location, index, array) => (
                <>
                  <span class="inline-flex items-center rounded-full border border-orange-200/50 bg-linear-to-r from-orange-50 to-amber-50 px-3 py-1 text-sm font-medium text-orange-700">
                    {location.trim()}
                  </span>
                  {index < array.length - 1 && (
                    <Navigation2
                      aria-hidden
                      class="size-3.5 shrink-0 rotate-90 text-orange-400"
                    />
                  )}
                </>
              ))}
            </div>

            {day.text.map((item) => (
              <div class="flex items-start gap-3">
                <div class="mbs-1 flex size-6 shrink-0 items-center justify-center rounded-full bg-linear-to-br from-green-500 to-emerald-600 text-white shadow-xs">
                  <Check
                    aria-hidden
                    class="size-3.5"
                  />
                </div>
                <p class="flex-1 text-sm leading-relaxed text-neutral-700 sm:text-base">{item}</p>
              </div>
            ))}

            {(day.accommodation || day.meals || day.activities || day.arrival) && (
              <div class="mbs-4 grid gap-3 sm:grid-cols-2">
                {day.accommodation && (
                  <div class="flex items-center gap-2 rounded-lg border-[3px] border-amber-200 bg-amber-50 px-3 py-2">
                    <Hotel
                      aria-hidden
                      class="size-5 shrink-0 text-amber-600"
                    />
                    <div>
                      <div class="text-xs font-semibold text-amber-700">{accommodationLabel}</div>
                      <div class="text-sm text-amber-900">{day.accommodation}</div>
                    </div>
                  </div>
                )}
                {day.meals && (
                  <div class="flex items-center gap-2 rounded-lg border-[3px] border-amber-200 bg-amber-50 px-3 py-2">
                    <Utensils
                      aria-hidden
                      class="size-5 shrink-0 text-amber-600"
                    />
                    <div>
                      <div class="text-xs font-semibold text-amber-700">{mealsLabel}</div>
                      <div class="text-sm text-amber-900">{day.meals}</div>
                    </div>
                  </div>
                )}
                {day.activities && (
                  <div class="flex items-center gap-2 rounded-lg border-[3px] border-emerald-200 bg-emerald-50 px-3 py-2">
                    <Tent
                      aria-hidden
                      class="size-5 shrink-0 text-emerald-600"
                    />
                    <div>
                      <div class="text-xs font-semibold text-emerald-700">{activitiesLabel}</div>
                      <div class="text-sm text-emerald-900">{day.activities}</div>
                    </div>
                  </div>
                )}
                {day.arrival && (
                  <div class="flex items-center gap-2 rounded-lg border-[3px] border-sky-200 bg-sky-50 px-3 py-2">
                    <Clock
                      aria-hidden
                      class="size-5 shrink-0 text-sky-600"
                    />
                    <div>
                      <div class="text-xs font-semibold text-sky-700">{arrivalLabel}</div>
                      <div class="text-sm text-sky-900">{day.arrival}</div>
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
      </div>
    ))
  }
</div>
