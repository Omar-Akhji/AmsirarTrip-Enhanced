---
import { useTranslations } from "@/i18n/utils";
import { Image } from "astro:assets";

import { getCollection } from "astro:content";

const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);

const destinationEntries = await getCollection("destinations");
const cities = destinationEntries.map((entry) => entry.data);
---

<section
  aria-labelledby="featured-heading"
  class="relative isolate overflow-hidden bg-neutral-50 py-24 text-neutral-900"
  id="featured"
>
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(248,250,252,0.3),transparent_70%)]"
  >
  </div>
  <div class="relative z-10 mx-auto px-4 max-inline-7xl">
    <div
      class="mx-auto mbe-16 space-y-4 text-center max-inline-4xl"
      data-animate="fade-up"
    >
      <p
        class="inline-flex items-center justify-center rounded-full border-2 border-orange-400 px-6 py-3 text-sm font-semibold tracking-[0.45em] text-orange-600 uppercase"
      >
        {t("featured.smTitle")}
      </p>
      <h2
        class="mt-6 text-2xl leading-tight font-semibold tracking-widest text-neutral-900 uppercase text-shadow-md sm:text-3xl sm:tracking-[0.15em] md:text-4xl md:tracking-[0.2em]"
        id="featured-heading"
      >
        {t("featured.lgTitle")}
      </h2>
      <div
        aria-hidden="true"
        class="mx-auto mbs-4 rounded-full bg-orange-500 block-1 inline-20"
      >
      </div>
    </div>

    <div class="featured-row grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        cities.map((city, index) => (
          <div
            data-animate="fade-up"
            style={`transition-delay: ${index * 150}ms`}
          >
            <article class="card-article relative block aspect-4/3 overflow-hidden rounded-xl">
              <Image
                alt={t(city.altKey)}
                class="card-img absolute inset-0 size-full object-cover"
                height={city.height}
                loading="lazy"
                src={city.image}
                width={city.width}
              />
              <div class="card-data">
                <h3 class="card-title text-shadow-md">{t(city.titleKey)}</h3>
                <p class="card-text">{t(city.descriptionKey)}</p>
              </div>
            </article>
          </div>
        ))
      }
    </div>
  </div>
</section>
