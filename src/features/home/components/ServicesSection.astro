---
import servicesBg from "@/assets/images/services-bg.webp";
import { useTranslations } from "@/i18n/utils";
import { Image } from "astro:assets";

const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);

const services = [
  { key: "handcrafted", icon: "/icons/globus-icon.svg", altKey: "services.cards.handcrafted.alt" },
  { key: "guide", icon: "/icons/map-icon.svg", altKey: "services.cards.guide.alt" },
  { key: "price", icon: "/icons/dollar-icon.svg", altKey: "services.cards.price.alt" },
];
---

<section
  aria-labelledby="services-heading"
  class="relative isolate overflow-hidden py-20 text-orange-200 sm:py-24"
  id="services"
>
  <Image
    alt=""
    class="absolute inset-0 -z-20 h-full w-full object-cover"
    height={1277}
    loading="lazy"
    src={servicesBg}
    width={1920}
  />
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-black/40"
  >
  </div>
  <div class="relative mx-auto px-4 max-inline-6xl sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-10">
      <div
        class="mx-auto space-y-4 text-center max-inline-3xl"
        data-animate="fade-up"
      >
        <p
          class="inline-flex items-center justify-center rounded-full border-2 border-orange-100 px-6 py-3 text-sm font-semibold tracking-[0.45em] text-white uppercase sm:tracking-[0.3em]"
        >
          {t("services.smTitle")}
        </p>
        <h2
          class="mbs-4 text-2xl leading-tight font-semibold tracking-widest text-white uppercase text-shadow-md sm:text-3xl sm:tracking-[0.15em] md:text-4xl md:tracking-[0.2em]"
          id="services-heading"
        >
          {t("services.lgTitle")}
        </h2>
        <div
          aria-hidden="true"
          class="mx-auto mbs-4 rounded-full bg-orange-200 block-1 inline-20"
        >
        </div>
      </div>
    </div>

    <div class="mbs-12 grid justify-items-stretch gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service, index) => (
          <div
            class:list={[`flex size-full`, { "md:col-span-2 lg:col-span-1": index === 2 }]}
            data-animate="fade-up"
            style={`transition-delay: ${index * 150}ms`}
          >
            <article class="group relative flex flex-col items-center rounded-3xl border border-white/10 bg-white/5 p-8 text-center shadow-xs ring-1 ring-black/5 backdrop-blur-sm transition inline-full pointer-fine:hover:-translate-y-1 pointer-fine:hover:bg-white/10 pointer-fine:hover:shadow-md">
              <div class="mbe-6 inline-flex size-25 items-center justify-center rounded-full bg-white/5 ring-1 ring-white/10">
                <Image
                  alt={t(service.altKey)}
                  class="size-15"
                  height={60}
                  src={service.icon}
                  width={60}
                />
              </div>
              <h3 class="text-xl font-semibold text-white">
                {t(`services.cards.${service.key}.title`)}
              </h3>
              <p class="mbs-3 text-sm text-white">{t(`services.cards.${service.key}.text`)}</p>
              <div
                aria-hidden
                class="pointer-events-none absolute inset-0 rounded-3xl border border-transparent transition group-hover:border-orange-200/60"
              />
            </article>
          </div>
        ))
      }
    </div>
  </div>
</section>
