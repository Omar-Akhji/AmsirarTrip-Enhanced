---
import { useTranslations } from "@/i18n/utils";

const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);

const statHighlights = [
  {
    id: "experience",
    value: "20+",
    label: t("about.experienceTitle"),
    description: t(
      "home.stats.experience",
      "Years perfecting Sahara crossings and Atlas escapades.",
    ),
  },
  {
    id: "routes",
    value: "35+",
    label: t("excursion.stats.routes", "Signature excursions"),
    description: t("home.stats.routes", "Handpicked story-driven routes from dunes to oceans."),
  },
  {
    id: "care",
    value: "24/7",
    label: t("excursion.stats.support", "On-trip support"),
    description: t("home.stats.care", "Dedicated coordinators for every mile of your journey."),
  },
];
---

<section
  aria-labelledby="home-highlights"
  class="py-12"
>
  <div class="mx-auto px-4 max-inline-7xl">
    <div
      class="mx-auto mbe-10 space-y-4 text-center max-inline-4xl"
      data-animate="fade-up"
    >
      <p
        class="inline-flex items-center justify-center rounded-full border-2 border-white bg-orange-600 px-6 py-3 text-sm font-semibold tracking-[0.45em] text-white uppercase"
      >
        {t("about.smTitle")}
      </p>
      <h2
        class="mbs-4 text-2xl leading-tight font-semibold text-shadow-md sm:text-3xl md:text-4xl"
        id="home-highlights"
      >
        {t("about.experienceTitle")}
      </h2>
      <div
        aria-hidden="true"
        class="mx-auto mbs-4 rounded-full bg-orange-500 block-1 inline-20"
      >
      </div>
      <p class="mbs-4 text-base text-taupe-600">{t("tours.detailsSubtitle")}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {
        statHighlights.map((stat, index) => (
          <div
            class="flex size-full"
            data-animate="fade-up"
            style={`transition-delay: ${index * 150}ms`}
          >
            <article class="rounded-3xl border border-orange-100 bg-white p-6 shadow-xs shadow-orange-100/70 inline-full">
              <p class="text-4xl font-bold text-orange-600">{stat.value}</p>
              <h3 class="mbs-3 text-lg font-semibold text-zinc-900">{stat.label}</h3>
              <p class="mbs-2 text-sm text-taupe-600">{stat.description}</p>
            </article>
          </div>
        ))
      }
    </div>
  </div>
</section>
