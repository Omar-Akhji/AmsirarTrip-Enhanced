---
import { ArrowRight, Mail, MapPin, Phone } from "lucide-astro";
import { useTranslations } from "@/i18n/utils";
import PageHeader from "@/shared/layout/PageHeader.astro";

const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);

const contactMethods = [
  {
    id: "phone",
    icon: Phone,
    title: t("contact.card.phoneTitle", "Feel free to contact us - we're here to help"),
    description: t(
      "contact.card.phoneSeo",
      "Have a quick question or want to book now? Our local team answers calls and messages promptly - reach out and we'll help plan the perfect Morocco trip.",
    ),
  },
  {
    id: "email",
    icon: Mail,
    title: t("contact.card.emailTitle", "Send a message - we'll reply with a tailored plan"),
    description: t(
      "contact.card.emailSeo",
      "Prefer to write? Send us your plans, dates and priorities - we'll prepare a personalised itinerary and respond quickly with options and clear next steps.",
    ),
  },
  {
    id: "location",
    icon: MapPin,
    title: t("contact.card.visitTitle", "Visit our Marrakech office - friendly, local support"),
    description: t(
      "contact.card.visitSeo",
      "Drop by for an in-person chat, help with bookings, or to learn more about our desert excursions and private tours - our team is ready to welcome you.",
    ),
  },
];
---

<PageHeader
  bgImage="/images/Header/header-1.webp"
  breadcrumbs={[{ label: t("nav.home"), href: "/" }, { label: t("nav.contact") }]}
  gradientPosition="top-right"
  smTitle={t("contact.smTitle", "get in touch with us")}
  subtitle={t("contact.headerSubtitle")}
  title={t("contact.title")}
>
  <a
    class="inline-flex items-center gap-2 rounded-full border border-white/60 px-6 py-3 text-sm font-semibold text-white/90 transition text-shadow-xs pointer-fine:hover:bg-white/10"
    href="#contact-form-section"
  >
    <span>{t("contact.form.cta", "Send message")}</span>
    <ArrowRight className="size-4" />
  </a>
  <a
    class="inline-flex items-center gap-2 rounded-full bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition text-shadow-xs pointer-fine:hover:-translate-y-0.5 pointer-fine:hover:bg-white/20"
    href="https://wa.me/212661173144"
    rel="noopener noreferrer"
    target="_blank"
  >
    <svg
      aria-hidden="true"
      class="size-4"
      fill="currentColor"
      viewBox="0 0 24 24"
      ><path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
      ></path></svg
    >
    <span>WhatsApp</span>
  </a>
</PageHeader>

<section
  aria-label="Contact Methods"
  class="relative isolate py-16"
>
  <div class="mx-auto px-4 max-inline-7xl">
    <div class="grid gap-6 md:grid-cols-3">
      {
        contactMethods.map((method, index) => (
          <div
            class="flex block-full inline-full"
            data-animate="fade-up"
            style={`transition-delay: ${index * 150}ms`}
          >
            <article
              aria-label={typeof method.title === "string" ? method.title : undefined}
              class="contact-info-card group rounded-3xl border border-orange-100 bg-white px-6 py-8 shadow-lg shadow-orange-100/70 transition inline-full pointer-fine:hover:-translate-y-1 pointer-fine:hover:shadow-xl"
            >
              <div class="mbe-4 inline-flex items-center justify-center rounded-full bg-orange-50 text-orange-600 transition block-14 inline-14 group-hover:bg-orange-600 group-hover:text-white">
                <method.icon className="size-6" />
              </div>
              <h3 class="text-xl font-semibold text-zinc-900">{method.title}</h3>
              <p class="mbs-3 text-base leading-relaxed text-zinc-700">{method.description}</p>
            </article>
          </div>
        ))
      }
    </div>
  </div>
</section>

<section
  aria-labelledby="contact-form-heading"
  class="bg-neutral-50"
  id="contact-form-section"
>
  <div class="mx-auto px-4 pbs-16 max-inline-7xl">
    <div class="section-header text-center">
      <p
        class="inline-flex items-center justify-center rounded-full border-2 border-orange-400 px-6 py-3 text-sm font-semibold tracking-[0.45em] text-orange-600 uppercase"
      >
        {t("contact.form.badge", "Plan with locals")}
      </p>
      <h2
        class="mbs-6 text-2xl leading-tight font-semibold tracking-widest text-neutral-900 uppercase sm:text-3xl sm:tracking-[0.15em] md:text-4xl md:tracking-[0.2em]"
        id="contact-form-heading"
      >
        {t("contact.lgTitle", "contact us")}
      </h2>
      <div
        aria-hidden="true"
        class="mx-auto mbs-4 rounded-full bg-orange-500 block-1 inline-20"
      >
      </div>
    </div>
  </div>
</section>

<slot />

<section
  aria-labelledby="location-heading"
  class="relative bg-zinc-50 pbe-16"
  id="location"
>
  <div class="mx-auto px-4 max-inline-7xl">
    <div class="mbe-12 p-7 text-center tracking-wide uppercase">
      <p
        class="inline-flex items-center justify-center rounded-full border-2 border-orange-400 px-6 py-3 text-sm font-semibold tracking-[0.45em] text-orange-600 uppercase"
      >
        {t("contact.location.smTitle")}
      </p>
      <h2
        class="mbs-6 text-2xl leading-tight font-semibold tracking-widest text-neutral-900 uppercase sm:text-3xl sm:tracking-[0.15em] md:text-4xl md:tracking-[0.2em]"
        id="location-heading"
      >
        {t("contact.location.lgTitle")}
      </h2>
      <div
        aria-hidden="true"
        class="mx-auto mbs-4 rounded-full bg-orange-500 block-1 inline-20"
      >
      </div>
    </div>
    <div class="overflow-hidden rounded-3xl shadow-2xl ring-1 ring-zinc-200">
      <div data-animate="zoom-in">
        <iframe
          allowfullscreen
          aria-label="Interactive map showing Amsirar Trip agency location in Marrakech"
          class="border-0 block-75 md:block-100 lg:block-125"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          sandbox="allow-scripts allow-same-origin allow-popups"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3399.999!2d-8.0257651!3d31.6259758!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xdafef007a3f58d3%3A0xa6485d9ed7022b4c!2sAmsirar+Travel!5e0!3m2!1sen!2sma!4v1699999999999!5m2!1sen!2sma"
          title="Amsirar Trip Agency Location - Marrakech, Morocco"
          width="100%"
        ></iframe>
      </div>
    </div>
  </div>
</section>
