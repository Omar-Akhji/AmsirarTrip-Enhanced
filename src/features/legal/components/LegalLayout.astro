---
import { useTranslations } from "@/i18n/utils";
import PageHeader from "@/shared/layout/PageHeader.astro";
import { getCollection, render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  docId: "privacy-policy" | "terms-of-service";
  headingId: string;
}

const { docId, headingId } = Astro.props;
const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);

const legalEntries = await getCollection("legal");
const entry = legalEntries.find(
  (legalEntry) =>
    legalEntry.id.toLowerCase() === `${locale}/${docId}`.toLowerCase()
    || legalEntry.id.toLowerCase() === `en/${docId}`.toLowerCase(),
);

let Content: Awaited<ReturnType<typeof render>>["Content"] | null = null;
const meta = entry?.data;

if (entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}
---

<PageHeader
  breadcrumbs={[{ label: t("nav.home"), href: "/" }, { label: meta?.title || docId }]}
  headingId={headingId}
  subtitle={meta?.subtitle || ""}
  title={meta?.title || docId}
/>

<main>
  <section
    aria-labelledby={headingId}
    class="relative isolate overflow-hidden bg-neutral-50 py-16 text-neutral-900 sm:py-24"
  >
    <div
      aria-hidden="true"
      class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(248,250,252,0.3),transparent_70%)]"
    >
    </div>
    <div class="relative z-10 mx-auto px-4 max-inline-4xl">
      {
        meta?.lastUpdated && (
          <div class="mbe-8 text-center text-sm font-medium text-neutral-500">
            {meta.lastUpdated}
          </div>
        )
      }

      <article class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-neutral-200/80 sm:p-12">
        <div
          class="prose prose-neutral max-w-none space-y-6 text-neutral-700 [&_h2]:mbs-8 [&_h2]:mbe-3 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-neutral-900 [&_p]:leading-relaxed [&_strong]:font-semibold [&_strong]:text-neutral-900"
        >
          {Content ? <Content /> : <p>Content not available for this language.</p>}
        </div>
      </article>

      <div class="mbs-12 text-center">
        <a
          class="inline-flex items-center gap-2 font-medium text-orange-600 transition-colors pointer-fine:hover:text-orange-700"
          href={getRelativeLocaleUrl(locale, "/")}
        >
          <svg
            class="size-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
            ></path>
          </svg>
          {t("legal.backToHome")}
        </a>
      </div>
    </div>
  </section>
</main>
