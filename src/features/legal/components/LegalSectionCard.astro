---
import { useTranslations } from "@/i18n/utils";

interface Props {
  section: { id: string; titleKey: string; contentKey: string };
  index: number;
}

const { section, index } = Astro.props;
const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);
---

<article
  aria-labelledby={`legal-${section.id}-heading`}
  class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-xs transition-shadow sm:p-8 pointer-fine:hover:shadow-md"
  id={`legal-${section.id}`}
>
  <h2
    class="mbe-4 flex items-center gap-3 text-lg font-semibold text-neutral-900 sm:text-xl"
    id={`legal-${section.id}-heading`}
  >
    <span
      class="flex size-8 shrink-0 items-center justify-center rounded-full bg-orange-500 text-sm font-bold text-white"
      >{index + 1}</span
    >
    {t(section.titleKey)}
  </h2>
  <div class="prose prose-slate prose-sm max-inline-none">
    <p class="leading-relaxed text-neutral-600">{t(section.contentKey)}</p>
  </div>
</article>
