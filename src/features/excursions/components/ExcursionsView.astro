---
import bgImage from "@/assets/images/Header/header-1.webp";
import { EXCURSIONS_DATA } from "@/features/excursions/data/excursionsData";
import { useTranslations } from "@/i18n/utils";
import PageHeader from "@/shared/layout/PageHeader.astro";
import StatHighlights from "@/shared/ui/StatHighlights.astro";
import TripCard from "@/shared/ui/TripCard.astro";
import { ArrowRight } from "@lucide/astro";

const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);

const highlightStats = [
  {
    id: "routes",
    value: "6+",
    label: t("excursion.stats.routes") || "Signature excursions",
    description:
      t("excursion.stats.routesDesc") || "Handpicked day trips from waterfalls to desert sunsets.",
  },
  {
    id: "local",
    value: "100%",
    label: t("excursion.stats.local") || "Local expertise",
    description:
      t("excursion.stats.localDesc") || "Guided by Marrakech-based storytellers and drivers.",
  },
  {
    id: "support",
    value: "24/7",
    label: t("excursion.stats.support") || "On-trip support",
    description:
      t("excursion.stats.supportDesc") || "Flexible departures and concierge-style planning.",
  },
];
---

<PageHeader
  bgImage={bgImage}
  breadcrumbs={[{ label: t("nav.home"), href: "/" }, { label: t("nav.excursions") }]}
  subtitle={t("excursion.headerSubtitle")}
  title={t("excursion.title")}
>
  <a
    class="inline-flex items-center gap-2 rounded-full bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition text-shadow-xs pointer-fine:hover:-translate-y-0.5 pointer-fine:hover:bg-white/20"
    href="https://www.tripadvisor.de/Attraction_Review-g293734-d32584739-Reviews-Amsirar_Travel-Marrakech_Marrakech_Safi.html"
    rel="noopener noreferrer"
    target="_blank"
  >
    Offers on TripAdvisor
  </a>
  <a
    class="inline-flex items-center gap-2 rounded-full border border-white/60 px-6 py-3 text-sm font-semibold text-white/90 transition text-shadow-xs pointer-fine:hover:bg-white/10"
    href="#excursions-grid"
  >
    <span>{t("excursion.detailsTitle")}</span>
    <ArrowRight class="size-4" />
  </a>
</PageHeader>

<main class="text-zinc-900">
  <section
    aria-labelledby="excursion-highlights"
    class="py-12"
  >
    <div class="mx-auto px-4 max-inline-7xl">
      <div
        class="mx-auto mbe-10 text-center max-inline-3xl"
        data-animate="fade-up"
      >
        <p
          class="inline-flex items-center justify-center rounded-full border-2 border-white bg-orange-700 px-6 py-3 text-sm font-semibold tracking-[0.45em] text-white uppercase"
        >
          {t("excursion.blog.smTitle")}
        </p>
        <h2
          class="mbs-4 text-2xl leading-tight font-semibold sm:text-3xl md:text-4xl"
          id="excursion-highlights"
        >
          {t("excursion.detailsTitle")}
        </h2>
        <div
          aria-hidden="true"
          class="mx-auto mbs-4 rounded-full bg-orange-500 block-1 inline-20"
        >
        </div>
        <p class="mbs-4 text-base text-taupe-600">{t("excursion.detailsSubtitle")}</p>
      </div>

      <div data-animate="fade-up">
        <StatHighlights stats={highlightStats} />
      </div>
    </div>
  </section>

  <section
    aria-labelledby="excursion-grid-heading"
    class="border-t border-zinc-200 bg-linear-to-b from-zinc-50 to-white py-16"
    id="excursions-grid"
  >
    <div class="mx-auto px-4 max-inline-7xl">
      <div
        class="mbe-12 text-center"
        data-animate="fade-up"
      >
        <h2
          class="mbs-4 text-2xl leading-tight font-semibold sm:text-3xl md:text-4xl"
          id="excursion-grid-heading"
        >
          {t("excursion.blog.lgTitle")}
        </h2>
        <div
          aria-hidden="true"
          class="mx-auto mbs-4 rounded-full bg-orange-500 block-1 inline-20"
        >
        </div>
        <p class="mbs-4 text-base text-taupe-600">{t("excursion.sectionSubtitle")}</p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          EXCURSIONS_DATA.map((excursion, index) => (
            <div
              class="flex size-full"
              data-animate="fade-up"
              style={`transition-delay: ${index * 150}ms`}
            >
              <TripCard
                badge={t("excursion.card.category")}
                item={{
                  image: excursion.image,
                  imageAlt: t(excursion.alt),
                  title: t(excursion.title),
                  description: t(excursion.description),
                  route: excursion.route,
                }}
                priority={index < 2}
                tagline={t(excursion.tagline)}
                translations={{
                  title: t(excursion.title),
                  description: t(excursion.description),
                  exploreLink: t("excursion.exploreLink"),
                }}
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</main>
