---
import { useTranslations } from "@/i18n/utils";
import TripLayout from "@/shared/layout/TripLayout.astro";
import ExcursionInfo from "./ExcursionInfo.astro";

interface Props {
  excursionKey: string;
  imageSrc: string;
  locale: string;
}

const { excursionKey, imageSrc, locale } = Astro.props;
const t = useTranslations(locale);

const highlights: string[] = [
  t(`${excursionKey}.highlights.0`),
  t(`${excursionKey}.highlights.1`),
  t(`${excursionKey}.highlights.2`),
  t(`${excursionKey}.highlights.3`),
].filter(Boolean);

const rawSidebarItems = t.raw("excursion.sidebar.items");
const sidebarItems = Array.isArray(rawSidebarItems) ? (rawSidebarItems as string[]) : [];

const title = t(`${excursionKey}.title`);
const distanceLabel = t(`${excursionKey}.distanceValue`, "~191 km from Marrakech");
const durationLabel = t(`${excursionKey}.durationLabel`, "Full-day excursion");
const altText = t(`${excursionKey}.alt`);
---

<TripLayout
  breadcrumbs={[
    { label: t("nav.home"), href: "/" },
    { label: t("nav.excursions"), href: "/excursions" },
    { label: t("excursion.detailsTitle") },
  ]}
  headingId="excursion-title"
  imageAlt={`${altText} - Morocco excursion destination`}
  imageSrc={imageSrc}
  pageSubtitle={t("excursion.detailsSubtitle")}
  pageTitle={t("excursion.detailsTitle")}
  sectionId="excursion-single"
  sidebar={{
    sidebarTitle: t("excursion.sidebar.title"),
    mainBrand: t("excursion.sidebar.mainBrand"),
    intro: t("excursion.sidebar.intro"),
    details: t("excursion.sidebar.details"),
    sidebarItems,
    conclusion: t("excursion.sidebar.conclusion"),
    ctaTitle: t("excursion.sidebar.ctaTitle"),
    ctaDescription: t("excursion.sidebar.ctaDescription"),
    ctaPoint01: t("excursion.sidebar.ctaPoint01"),
    ctaPoint02: t("excursion.sidebar.ctaPoint02"),
    ctaPoint03: t("excursion.sidebar.ctaPoint03"),
  }}
  smTitle={t("excursion.detailsTitle")}
  title={title}
>
  <Fragment slot="content">
    <div
      data-animate="fade-up"
      style="transition-delay:150ms"
    >
      <div class="grid gap-4 sm:grid-cols-2">
        <div
          class="inline-flex items-center gap-3 rounded-full border border-orange-100 bg-orange-50 px-5 py-3"
        >
          <svg
            aria-hidden
            class="size-5 text-orange-500"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              d="M3 12h18"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-width="2"
            ></path>
          </svg>
          <div class="text-start">
            <div class="text-sm font-semibold text-orange-600">{distanceLabel}</div>
            <div class="text-xs font-semibold text-amber-300">
              {t("excursion.common.distanceLabel", "Distance")}
            </div>
          </div>
        </div>

        <div
          class="inline-flex items-center gap-3 rounded-full border border-amber-100 bg-amber-50 px-5 py-3"
        >
          <svg
            aria-hidden
            class="size-5 text-amber-500"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              d="M12 3v18"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-width="2"
            ></path>
          </svg>
          <div class="text-start">
            <div class="text-sm font-semibold text-amber-600">{durationLabel}</div>
            <div class="text-xs font-semibold text-amber-300">
              {t("excursion.common.durationLabel", "Duration")}
            </div>
          </div>
        </div>
      </div>
    </div>

    <ExcursionInfo
      highlights={highlights}
      highlightsTitle={t("excursion.common.highlights")}
      overview={t(`${excursionKey}.overview`)}
      overviewTitle={t("excursion.common.overview")}
    />
  </Fragment>
  <slot />
</TripLayout>
