---
import { useTranslations } from "@/i18n/utils";
import PageHeader from "@/shared/layout/PageHeader.astro";

const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);

const factStats = [
  {
    id: "photos",
    icon: "/icons/camera-icon.svg",
    value: 12_200,
    duration: 14_000,
    label: t("about.facts.photos"),
  },
  {
    id: "beaches",
    icon: "/icons/beach-icon.svg",
    value: 4500,
    duration: 14_000,
    label: t("about.facts.beaches"),
  },
  {
    id: "mountains",
    icon: "/icons/mountain-icon.svg",
    value: 840,
    duration: 9000,
    label: t("about.facts.mountains"),
  },
  {
    id: "cruises",
    icon: "/icons/travel-icon.svg",
    value: 1200,
    duration: 10_000,
    label: t("about.facts.cruises"),
  },
];
---

<PageHeader
  bgImage="/images/Header/header-1.webp"
  breadcrumbs={[{ label: t("nav.home"), href: "/" }, { label: t("nav.about") }]}
  headingId="about-page-title"
  subtitle={t("about.headerSubtitle")}
  title={t("about.title")}
>
  <a
    class="inline-flex items-center gap-2 rounded-full border border-white/60 px-6 py-3 text-sm font-semibold text-white/90 transition text-shadow-xs pointer-fine:hover:bg-white/10"
    href="#about"
  >
    <span>{t("about.ourStory")}</span>
    <span class="sr-only">{t("about.ourStory")}</span>
  </a>
  <a
    class="inline-flex items-center gap-2 rounded-full bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition text-shadow-xs pointer-fine:hover:-translate-y-0.5 pointer-fine:hover:bg-white/20"
    href="#facts"
  >
    {t("about.facts.smTitle")}
  </a>
</PageHeader>

<main>
  <section
    aria-labelledby="our-story-heading"
    class="relative isolate overflow-hidden bg-neutral-50 py-24 text-neutral-900"
    id="about"
  >
    <div
      aria-hidden="true"
      class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(248,250,252,0.3),transparent_70%)]"
    >
    </div>
    <div class="relative z-10 mx-auto px-4 max-inline-7xl">
      <div class="mx-auto mbe-16 text-center max-inline-4xl">
        <p
          class="inline-flex items-center justify-center rounded-full border-2 border-orange-400 px-6 py-3 text-sm font-semibold tracking-[0.45em] text-orange-600 uppercase"
        >
          {t("about.smTitle")}
        </p>
        <h2
          class="mbs-6 text-2xl leading-tight font-semibold tracking-widest text-neutral-900 uppercase sm:text-3xl sm:tracking-[0.15em] md:text-4xl md:tracking-[0.2em]"
          id="our-story-heading"
        >
          {t("about.ourStory")}
        </h2>
      </div>

      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="order-2 lg:order-1">
          <div
            class="inline-full"
            data-animate="fade-up"
          >
            <article class="space-y-8">
              <div class="space-y-6">
                <p class="text-sm leading-relaxed text-neutral-700">{t("about.experienceText1")}</p>
                <p class="text-sm leading-relaxed text-neutral-700">{t("about.experienceText2")}</p>
                <p class="text-sm leading-relaxed text-neutral-700">{t("about.experienceText3")}</p>
              </div>

              <div class="border-t border-zinc-700 pbs-8">
                <h3 class="mbe-6 text-xl font-semibold text-orange-600">
                  {t("about.whyTrustTitle")}
                </h3>
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                  {
                    [1, 2, 3, 4].map((number_) => (
                      <div class="flex items-start gap-3">
                        <div class="flex size-8 shrink-0 items-center justify-center rounded-full bg-orange-500 text-sm font-bold text-white">
                          {number_}
                        </div>
                        <p class="flex-1 text-sm leading-relaxed text-neutral-700">
                          {t(`about.whyTrust.point${number_}`)}
                        </p>
                      </div>
                    ))
                  }
                </div>
              </div>

              <blockquote
                class="relative overflow-hidden rounded-r-2xl bg-linear-to-r from-orange-50 to-transparent py-4 ps-8 text-neutral-600 italic ring-1 ring-orange-200/50 ring-inset"
              >
                <div
                  aria-hidden="true"
                  class="absolute inset-s-0 top-0 bottom-0 bg-orange-400 block-full inline-1.5"
                >
                </div>
                <p class="text-sm leading-relaxed">{t("about.conclusionText")}</p>
              </blockquote>
            </article>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <div
            data-animate="zoom-in"
            style="transition-delay: 200ms"
          >
            <figure class="relative">
              <div
                class="absolute inset-0 rotate-3 transform rounded-3xl bg-linear-to-br from-orange-500/20 to-amber-500/20"
              >
              </div>
              <div
                class="relative aspect-4/3 overflow-hidden rounded-3xl bg-white mask-b-from-50% shadow-2xl"
              >
                <img
                  alt="Amsirar landscape showcasing traditional Moroccan architecture and culture"
                  class="absolute inset-0 size-full object-cover"
                  src="/images/about-img.webp"
                />
                <div
                  class="absolute inset-s-0 inset-e-0 bottom-0 bg-linear-to-t from-neutral-900/60 to-transparent p-6"
                >
                  <p class="text-sm font-medium text-neutral-100">
                    {t("about.imageCaption") || "Discover Morocco with Amsirar"}
                  </p>
                </div>
              </div>
            </figure>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    aria-labelledby="facts-heading"
    class="relative isolate overflow-hidden py-16"
    id="facts"
  >
    <div class="relative z-10 mx-auto px-4 inline-full max-inline-6xl">
      <div class="mx-auto text-center max-inline-3xl">
        <p
          class="inline-flex items-center justify-center rounded-full border-2 border-white bg-orange-600 px-6 py-3 text-sm font-semibold tracking-[0.45em] text-white uppercase sm:tracking-[0.3em]"
        >
          {t("about.facts.smTitle")}
        </p>
        <h2
          class="mbs-4 text-2xl leading-tight font-semibold tracking-widest text-zinc-900 uppercase text-shadow-md sm:text-3xl sm:tracking-[0.15em] md:text-4xl md:tracking-[0.2em]"
          id="facts-heading"
        >
          {t("about.facts.lgTitle")}
        </h2>
        <div
          aria-hidden="true"
          class="mx-auto mbs-4 rounded-full bg-orange-500 block-1 inline-20"
        >
        </div>
      </div>

      <div class="mbs-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          factStats.map((fact, index) => (
            <div
              class="flex size-full"
              data-animate="fade-up"
              style={`transition-delay: ${index * 150}ms`}
            >
              <article
                aria-labelledby={`fact-${fact.id}-label`}
                class="group relative flex size-full flex-col justify-between overflow-hidden rounded-2xl bg-zinc-900 px-8 py-10 text-center text-orange-200 shadow-xl ring-1 ring-white/10 transition-transform pointer-fine:hover:-translate-y-1 pointer-fine:hover:shadow-2xl"
              >
                <div
                  aria-hidden="true"
                  class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                >
                  <div class="absolute inset-0 bg-linear-to-br from-orange-500/10 via-amber-400/5 to-transparent" />
                </div>
                <div class="relative flex flex-col items-center gap-y-6">
                  <figure class="inline-flex size-24 items-center justify-center overflow-hidden rounded-full border-2 border-white/20 bg-white/5 p-3 text-orange-50 shadow-lg ring-2 shadow-orange-600/25 ring-white/10">
                    <img
                      alt=""
                      aria-hidden="true"
                      class="block size-full object-contain brightness-0 invert"
                      height={96}
                      src={fact.icon}
                      width={96}
                    />
                  </figure>
                  <div
                    aria-hidden="true"
                    class="text-4xl font-bold text-orange-200 text-shadow-md"
                  >
                    <span
                      class="inline-block"
                      data-count-duration={fact.duration}
                      data-count-to={fact.value}
                    >
                      {fact.value.toLocaleString()}
                    </span>
                  </div>
                  <h3
                    class="text-sm font-medium tracking-wide text-white/80 uppercase"
                    id={`fact-${fact.id}-label`}
                  >
                    {fact.label}
                  </h3>
                </div>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</main>
