---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Image } from "astro:assets";
import { generateOrganizationJsonLd, generateWebsiteJsonLd } from "../lib/structured-data";
import Footer from "../shared/layout/Footer.astro";
import Navbar from "../shared/layout/Navbar.astro";
import JsonLd from "../shared/ui/JsonLd.astro";
import { WHATSAPP_LINK } from "../lib/constants/contact";
import { LOCALES, DEFAULT_LOCALE } from "../i18n/locales";
import { ui } from "../i18n/ui";

const {
  title = "Amsirar Trip — Morocco Tours & Desert Adventures",
  description = "Explore Morocco with local experts. Authentic Sahara desert tours, imperial city excursions, Atlas Mountains treks, and private guided experiences. 20+ years serving travelers. Book your dream Morocco adventure today.",
} = Astro.props;

// Get the per-request nonce generated in middleware for CSP
const cspNonce = Astro.locals.cspNonce;

const locale = Astro.currentLocale || "en";
Object.assign(globalThis, { __TRANSLATIONS__: ui[locale as keyof typeof ui], __LOCALE__: locale });
const site = Astro.site!;
const pathname = Astro.url.pathname;

const segments = pathname.replace(/^\/+/, "").split("/").filter(Boolean);
const baseSegments = locale === "en" ? segments : segments.slice(1);
const basePath = "/" + baseSegments.join("/");

const canonicalURL = new URL(basePath, site).href;
const defaultOgImage = new URL("/images/Header/header-1.webp", site).href;

const ClientRouterWithNonce = ClientRouter as unknown as (_properties: {
  nonce: string;
}) => unknown;
---

<!doctype html>
<html
  class="no-js"
  itemscope
  itemtype="https://schema.org/WebPage"
  lang={locale}
>
  <head>
    <meta charset="UTF-8" />
    <link
      href="/sitemap-index.xml"
      rel="sitemap"
    />
    <script src="../scripts/no-js.ts"></script>

    <!--
      ClientRouter (View Transitions) generates inline scripts that are not
      easily nonce-able in Astro 7. 'strict-dynamic' in CSP allows these
      while still blocking third-party injected scripts.
    -->
    <ClientRouterWithNonce nonce={cspNonce} />

    <meta
      content={locale}
      name="app-locale"
    />
    <link
      as="font"
      crossorigin="anonymous"
      href="/fonts/Montserrat-VariableFont_wght.woff2"
      rel="preload"
      type="font/woff2"
    />
    <link
      as="font"
      crossorigin="anonymous"
      href="/fonts/StoryScript-Regular.woff2"
      rel="preload"
      type="font/woff2"
    />
    <link
      as="font"
      crossorigin="anonymous"
      href="/fonts/Yellowtail-Regular.woff2"
      rel="preload"
      type="font/woff2"
    />
    <meta
      content="width=device-width, initial-scale=1.0"
      name="viewport"
    />
    <meta
      content={Astro.generator}
      name="generator"
    />
    <meta
      content="#f97316"
      name="theme-color"
    />

    <title>{title}</title>
    <meta
      content={description}
      name="description"
    />

    <meta
      content={title}
      property="og:title"
    />
    <meta
      content={description}
      property="og:description"
    />
    <meta
      content={defaultOgImage}
      property="og:image"
    />
    <meta
      content={canonicalURL}
      property="og:url"
    />
    <meta
      content="website"
      property="og:type"
    />
    <meta
      content="Amsirar Trip"
      property="og:site_name"
    />
    <meta
      content={locale}
      property="og:locale"
    />
    {
      LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((l) => (
        <meta
          content={l}
          property="og:locale:alternate"
        />
      ))
    }

    <meta
      content="summary_large_image"
      name="twitter:card"
    />
    <meta
      content={title}
      name="twitter:title"
    />
    <meta
      content={description}
      name="twitter:description"
    />
    <meta
      content={defaultOgImage}
      name="twitter:image"
    />

    <link
      href={canonicalURL}
      rel="canonical"
    />

    {
      LOCALES.map((l) => {
        const href = l === DEFAULT_LOCALE ? canonicalURL : new URL(`/${l}${basePath}`, site).href;
        return (
          <link
            href={href}
            hreflang={l}
            rel="alternate"
          />
        );
      })
    }
    <link
      href={canonicalURL}
      hreflang="x-default"
      rel="alternate"
    />

    <link
      href="/sitemap-index.xml"
      rel="sitemap"
    />

    <link
      href="/favicon.png"
      rel="icon"
      type="image/png"
    />
    <link
      href="/horse-head.svg"
      rel="icon"
      type="image/svg+xml"
    />
    <link
      href="/favicon.png"
      rel="shortcut icon"
    />
    <link
      href="/icons/icon-512.png"
      rel="apple-touch-icon"
    />
    <link
      href="/site.webmanifest"
      rel="manifest"
    />

    <link
      as="image"
      href="/images/Header/header-1.webp"
      rel="preload"
      type="image/webp"
    />

    <JsonLd
      data={generateOrganizationJsonLd()}
      id="organization-jsonld"
    />
    <JsonLd
      data={generateWebsiteJsonLd()}
      id="website-jsonld"
    />
  </head>

  <body>
    <div
      class="hidden"
      id="app-translations"
    >
      {JSON.stringify(ui[locale as keyof typeof ui])}
    </div>
    <div
      class="fixed inset-0 z-999999 flex items-center justify-center bg-zinc-100 opacity-100 transition-opacity duration-450 ease-out data-[state=hidden]:pointer-events-none"
      data-state="visible"
      id="initial-loader"
      transition:persist
    >
      <svg
        class="size-12 origin-center animate-loader-rotate"
        height="48px"
        width="48px"
      >
        <circle
          cx="24"
          cy="24"
          fill="none"
          r="22"
          stroke="var(--color-light-grey-alt2)"
          stroke-width="4"
        ></circle>
        <circle
          class="animate-loader-dash stroke-orange-500"
          cx="24"
          cy="24"
          fill="none"
          r="22"
          stroke-dasharray="1 200"
          stroke-dashoffset="0"
          stroke-linecap="round"
          stroke-width="4"
        ></circle>
      </svg>
    </div>
    <script src="../scripts/loader.ts"></script>
    <script src="../scripts/scroll-animate.ts"></script>
    <script src="../scripts/webmcp-tools.ts"></script>

    <Navbar />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <a
      aria-label="Contact us on WhatsApp"
      class="fixed inset-e-6 bottom-6 z-50 flex size-16 items-center justify-center rounded-full border-[3px] border-whatsapp bg-white text-whatsapp shadow-lg transition-all duration-300 pointer-fine:hover:scale-110 pointer-fine:hover:shadow-xl pointer-fine:hover:brightness-110"
      href={WHATSAPP_LINK}
      rel="noopener noreferrer"
      target="_blank"
    >
      <span
        aria-hidden="true"
        class="absolute inset-0 -z-10 animate-ping rounded-full bg-whatsapp opacity-20 duration-1000"
      ></span>
      <Image
        alt="WhatsApp"
        class="size-10"
        height={40}
        src="/icons/whatsapp.svg"
        width={40}
      />
    </a>
  </body>
</html>
