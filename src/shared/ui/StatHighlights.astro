---
type Stat = { id: string; value: string; label: string; description: string };

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="grid gap-6 md:grid-cols-3">
  {
    stats.map((stat) => (
      <article class="rounded-3xl border border-orange-100 bg-white p-6 shadow-lg shadow-orange-100/70">
        <p class="text-4xl font-bold text-orange-600">{stat.value}</p>
        <h3 class="mbs-3 text-lg font-semibold text-zinc-900">{stat.label}</h3>
        <p class="mbs-2 text-sm text-taupe-600">{stat.description}</p>
      </article>
    ))
  }
</div>
