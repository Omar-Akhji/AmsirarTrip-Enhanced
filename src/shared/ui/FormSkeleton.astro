---
interface Props {
  variant?: "booking" | "contact";
}

const { variant = "booking" } = Astro.props;
---

<div class="animate-pulse space-y-4 rounded-2xl bg-white p-6 shadow-lg dark:bg-neutral-900">
  <div class="h-6 w-1/3 rounded bg-neutral-200 dark:bg-neutral-700"></div>
  <div class="space-y-3">
    <div class="h-10 rounded-lg bg-neutral-200 dark:bg-neutral-700"></div>
    <div class="h-10 rounded-lg bg-neutral-200 dark:bg-neutral-700"></div>
    <div class="h-10 rounded-lg bg-neutral-200 dark:bg-neutral-700"></div>
    {
      variant === "booking" && (
        <>
          <div class="h-10 rounded-lg bg-neutral-200 dark:bg-neutral-700" />
          <div class="grid grid-cols-2 gap-3">
            <div class="h-10 rounded-lg bg-neutral-200 dark:bg-neutral-700" />
            <div class="h-10 rounded-lg bg-neutral-200 dark:bg-neutral-700" />
          </div>
        </>
      )
    }
  </div>
  <div class="h-12 w-full rounded-full bg-orange-200 dark:bg-orange-900/40"></div>
  <p class="text-center text-sm text-neutral-400">Loading form…</p>
</div>
