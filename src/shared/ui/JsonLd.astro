---
interface Props {
  data: Record<string, unknown>;
  id?: string;
}

const { data, id } = Astro.props;
const json = JSON.stringify(data);
// Escape id to prevent XSS via unescaped template literal injection
const safeId = id?.replaceAll(/[^a-zA-Z0-9_-]/g, "");
---

<script
  id={safeId}
  is:inline
  set:html={json}
  type="application/ld+json"
/>
