---
import FooterBottomBar from "./footer/FooterBottomBar.astro";
import FooterBrand from "./footer/FooterBrand.astro";
import FooterContactInfo from "./footer/FooterContactInfo.astro";
import { FooterNewsletter } from "./footer/FooterNewsletter";
---

<footer
  class="relative z-10 mbs-0 box-border border-t-4 border-orange bg-zinc-950 pbs-6 text-start leading-[1.6] text-white shadow-[0_-8px_32px_rgba(0,0,0,0.5)] ring-1 ring-white/5 inline-full sm:pbs-8"
>
  <div
    aria-hidden="true"
    class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_top,rgba(15,23,42,0.8)_0%,rgba(15,23,42,0.4)_55%,transparent_90%)]"
  >
  </div>
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -inset-e-16 -top-16 size-72 rounded-full bg-orange/5 blur-3xl"></div>
    <div class="absolute -inset-s-20 -bottom-20 size-87.5 rounded-full bg-orange/3 blur-3xl"></div>
    <div
      class="absolute inset-s-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-radial from-white/2 to-transparent block-125 inline-125"
    >
    </div>
  </div>

  <div class="relative z-10">
    <div class="mx-auto p-8 max-inline-7xl">
      <div class="grid grid-cols-1 items-baseline gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-4">
        <div
          class="inline-full"
          data-animate="fade-up"
        >
          <FooterBrand />
        </div>
        <div
          class="inline-full"
          data-animate="fade-up"
          style="transition-delay: 150ms;"
        >
          <FooterContactInfo />
        </div>
        <div
          class="inline-full"
          data-animate="fade-up"
          style="transition-delay: 300ms;"
        >
          <FooterNewsletter client:visible />
        </div>
      </div>
    </div>

    <div
      class="inline-full"
      data-animate="fade-up"
      style="transition-delay: 450ms;"
    >
      <FooterBottomBar />
    </div>
  </div>
</footer>
