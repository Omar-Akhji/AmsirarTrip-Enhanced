---
import { useTranslations } from "@/i18n/utils";
import { cn } from "@/lib/utils";
import { NAV_LINKS, SOCIAL_LINKS } from "./constants";
import { LANGUAGES } from "@/i18n/locales";

const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);

const localize = (path: string) =>
  locale === "en" ? path : `/${locale}${path === "/" ? "" : path}`;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const normalizedPath =
  (LANGUAGES.some((l) => l.code === segments[0]) ?
    "/" + segments.slice(1).join("/")
  : pathname
  ).replace(/\/$/, "") || "/";

const isActive = (to: string) =>
  normalizedPath === to || (to !== "/" && normalizedPath.startsWith(to + "/"));
---

<div class="relative flex items-center gap-3 inline-full lg:hidden">
  <!-- Tablet Social Links & Language Selector -->
  <div class="hidden md:flex me-auto items-center gap-2">
    <ul class="flex items-center gap-2">
      {
        SOCIAL_LINKS.map((link) => (
          <li>
            <a
              aria-label={link.label}
              class:list={[
                "flex size-10 items-center justify-center rounded-full border-2 transition-all duration-150 pointer-fine:hover:-translate-y-0.5 pointer-fine:hover:shadow-[0_8px_18px_rgba(0,0,0,0.28)]",
                "group-not-data-scrolled:border-white/60 group-not-data-scrolled:bg-white/10 group-not-data-scrolled:text-white",
                link.accent,
              ]}
              href={link.href}
              rel={link.href.startsWith("http") ? "noopener noreferrer" : null}
              target={link.href.startsWith("http") ? "_blank" : null}
            >
              <img
                alt=""
                class="size-5 object-contain"
                src={link.icon}
              />
            </a>
          </li>
        ))
      }
    </ul>
    <slot name="language-selector-tablet" />
  </div>

  <a
    aria-label="Amsirar Trip Home"
    class="absolute inset-s-1/2 z-10 -translate-x-1/2 text-[1.4rem] font-semibold tracking-tight transition-colors duration-200 group-data-scrolled:text-dark-grey"
    href={localize("/")}
  >
    Amsirar <span
      class="font-brand font-light transition-colors duration-200 group-data-scrolled:text-orange"
      >Trip</span
    >
  </a>

  <!-- Mobile Language Selector -->
  <div class="flex md:hidden me-auto">
    <slot name="language-selector-mobile" />
  </div>

  <!-- Toggle Button -->
  <button
    aria-controls="navbar-collapse"
    aria-expanded="false"
    aria-label={t("nav.toggleMenu")}
    class="ms-2 flex size-10 items-center justify-center rounded-md text-lg transition-all duration-150 focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-orange bg-black/35 text-white group-data-scrolled:bg-orange group-data-scrolled:text-white"
    id="navbar-show-btn"
    type="button"
  >
    <!-- Hamburger icon -->
    <svg
      class="pointer-events-none size-5 menu-icon-hamburger"
      fill="none"
      height="24"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      viewBox="0 0 24 24"
      width="24"
      xmlns="http://www.w3.org/2000/svg"
    >
      <line
        x1="4"
        x2="20"
        y1="12"
        y2="12"
      ></line>
      <line
        x1="4"
        x2="20"
        y1="6"
        y2="6"
      ></line>
      <line
        x1="4"
        x2="20"
        y1="18"
        y2="18"
      ></line>
    </svg>
    <!-- X icon -->
    <svg
      class="pointer-events-none size-5 menu-icon-x hidden"
      fill="none"
      height="24"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      viewBox="0 0 24 24"
      width="24"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M18 6 6 18"></path>
      <path d="m6 6 12 12"></path>
    </svg>
  </button>

  <!-- Navigation dropdown panel -->
  <div
    aria-label="Navigation menu"
    class="navbar-collapse fixed inset-s-1/2 top-[calc(100%+0.75rem)] z-40 -translate-x-1/2 overflow-y-auto max-h-[calc(100vh-6rem)] rounded-2xl border border-white/20 bg-slate-950 text-white shadow-[0_20px_40px_rgba(0,0,0,0.3)] transition-all duration-300 inline-[min(1100px,calc(100vw-2rem))] group-data-scrolled:border-white/10 group-data-scrolled:bg-white group-data-scrolled:text-slate-900 pointer-events-none opacity-0 -translate-y-4 data-[state=open]:pointer-events-auto data-[state=open]:opacity-100 data-[state=open]:translate-y-0"
    data-state="closed"
    id="navbar-collapse"
  >
    <!-- Social Links inside dropdown (Mobile only) -->
    <div
      class="flex md:hidden items-center justify-center gap-4 border-b border-white/20 px-4 py-4 group-data-scrolled:border-light-grey-alt2/30"
    >
      <ul class="flex items-center gap-4">
        {
          SOCIAL_LINKS.map((link) => (
            <li>
              <a
                aria-label={link.label}
                class:list={[
                  "flex size-10 items-center justify-center rounded-full border-2 transition-all duration-150 pointer-fine:hover:-translate-y-0.5 pointer-fine:hover:shadow-[0_8px_18px_rgba(0,0,0,0.28)]",
                  "group-not-data-scrolled:border-white/60 group-not-data-scrolled:bg-white/10 group-not-data-scrolled:text-white",
                  link.accent,
                ]}
                href={link.href}
                rel={link.href.startsWith("http") ? "noopener noreferrer" : null}
                target={link.href.startsWith("http") ? "_blank" : null}
              >
                <img
                  alt=""
                  class="size-5 object-contain"
                  src={link.icon}
                />
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Navigation links -->
    <ul class="flex flex-col items-center gap-3 p-4">
      {
        NAV_LINKS.map((link) => {
          const active = isActive(link.to);
          return (
            <li>
              <a
                class:list={cn(
                  "mx-auto inline-flex items-center justify-center gap-2 rounded-full bg-transparent px-8 py-2.5 text-base font-medium text-white transition-all duration-200 inline-fit min-inline-40 group-data-scrolled:text-dark hover:bg-white/10 group-data-scrolled:hover:bg-light-grey",
                  active
                    && "bg-white/10 text-white shadow-[0_0_0_1px_rgb(0_0_0/5%)] backdrop-blur-xs group-data-scrolled:bg-orange group-data-scrolled:text-white group-data-scrolled:shadow-[0_10px_26px_oklch(56%_0.19_33deg/12%)]",
                )}
                href={localize(link.to)}
              >
                <span class="nav-label">{t(link.labelKey)}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</div>

<script src="./scripts/mobile-menu.ts"></script>
