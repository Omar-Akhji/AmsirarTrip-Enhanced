---
import { useTranslations } from "@/i18n/utils";
import { LANGUAGES } from "./constants";

interface Props {
  placement?: "left" | "right";
  size?: "sm" | "md";
  class?: string;
}

const { placement = "left", size = "md", class: className = "" } = Astro.props;

const locale = Astro.currentLocale || "en";
const t = useTranslations(locale);

const currentLanguage = LANGUAGES.find((l) => l.code === locale) || {
  code: "en",
  name: "English",
  shortName: "EN",
};

// Generate localized URLs on the server
const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const localeCodes = LANGUAGES.map((l) => l.code);

let basePath = pathname;
if (segments[0] && (localeCodes as readonly string[]).includes(segments[0])) {
  basePath = "/" + segments.slice(1).join("/");
}

// Clean trailing slashes
if (basePath.length > 1 && basePath.endsWith("/")) {
  basePath = basePath.slice(0, -1);
}
if (!basePath.startsWith("/")) {
  basePath = "/" + basePath;
}

const getLocalizedHref = (code: string) => {
  const path = code === "en" ? basePath : `/${code}${basePath === "/" ? "" : basePath}`;
  return path + Astro.url.search;
};

// Generate a unique ID to avoid collision if multiple selectors are on the same page
const popoverId = `lang-popover-${Math.floor(Math.random() * 100_000)}`;
---

<div class:list={["relative inline-block", className]}>
  <button
    aria-haspopup="menu"
    aria-label={`${t("language") || "Language"} - ${currentLanguage.shortName}`}
    class="relative cursor-pointer"
    popovertarget={popoverId}
    style={`anchor-name: --anchor-${popoverId}`}
    type="button"
  >
    <div
      class:list={[
        "flex items-center justify-center rounded-full border-2 transition-all duration-150 pointer-fine:hover:-translate-y-0.5 pointer-fine:hover:shadow-[0_8px_18px_rgba(0,0,0,0.28)]",
        "text-white group-data-scrolled:border-orange group-data-scrolled:bg-orange group-data-scrolled:shadow-[0_10px_24px_oklch(56%_0.19_33deg/35%)]",
        { "size-10 text-sm": size === "sm", "size-11 text-base font-semibold": size === "md" },
      ]}
    >
      <img
        alt=""
        class:list={["object-contain", { "size-5": size === "sm", "size-6.25": size === "md" }]}
        height="25"
        src="/icons/translate-icon-com.svg"
        width="25"
      />
    </div>
    <span
      aria-hidden="true"
      class:list={[
        "absolute -inset-e-1.5 -bottom-1 font-bold tracking-[0.04em] text-white rounded-full border-2 border-white bg-orange",
        {
          "px-1 py-px text-[0.6rem]": size === "sm",
          "px-1.5 py-0.5 text-[0.625rem]": size === "md",
        },
      ]}
    >
      {currentLanguage.shortName}
    </span>
  </button>

  <div
    aria-orientation="vertical"
    class:list={[
      "m-0 border-none bg-transparent p-0 outline-hidden",
      "fixed z-50 mbs-2 overflow-hidden rounded-xl border border-white/10 bg-dark/90 text-white shadow-xl backdrop-blur-xl inline-48",
      "transition-all duration-300 ease-out transition-discrete opacity-0 scale-95 starting:opacity-0 starting:scale-95",
    ]}
    id={popoverId}
    popover="auto"
    role="menu"
    style={`
      position-anchor: --anchor-${popoverId};
      top: anchor(bottom);
      ${placement === "left" ? "left: anchor(left);" : "right: anchor(right);"}
    `}
  >
    <div class="flex flex-col gap-1 p-1">
      {
        LANGUAGES.map((lang) => (
          <a
            aria-checked={lang.code === currentLanguage.code}
            class:list={[
              "flex items-center justify-between rounded-lg px-3 py-2 text-sm text-light-grey-alt2 transition-colors duration-150 inline-full hover:bg-white/10 hover:text-white group-data-scrolled:hover:bg-light-grey group-data-scrolled:hover:text-dark-grey",
              { "bg-white/10 text-white": lang.code === currentLanguage.code },
            ]}
            href={getLocalizedHref(lang.code)}
            role="menuitemradio"
          >
            <span class="flex items-center gap-3">
              <span class="font-medium">{lang.name}</span>
            </span>
            {lang.code === currentLanguage.code && (
              <div class="me-1 size-2 rounded-full group-data-scrolled:bg-orange" />
            )}
          </a>
        ))
      }
    </div>
  </div>
</div>
