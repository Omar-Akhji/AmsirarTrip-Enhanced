{
  "name": "amsirartrip",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "astro check",
    "dev": "astro dev",
    "doctor": "bunx react-doctor@latest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepare": "git update-index --assume-unchanged .husky/pre-commit 2>/dev/null || true",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.astro": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@vitejs/plugin-react": "6.0.2"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@astrojs/vue": "^7.0.1",
    "@lucide/astro": "^1.24.0",
    "astro": "^7.0.7",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-vue-next": "^1.0.0",
    "nodemailer": "^9.0.3",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "vue": "^3.5.39",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/ts-plugin": "^1.10.10",
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "astro-eslint-parser": "^2.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-unicorn": "^71.1.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.12",
    "prettier-plugin-jsdoc": "^1.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.14.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^7.0.2",
    "vue-eslint-parser": "^10.4.1"
  },
  "engines": {
    "node": ">=24.17.0",
    "bun": ">=1.3.0"
  }
}
