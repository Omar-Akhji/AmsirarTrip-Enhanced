{
  "name": "amsirartrip",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "astro check",
    "dev": "bunx --bun astro dev",
    "doctor": "bunx react-doctor@latest",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "git update-index --assume-unchanged .husky/pre-commit 2>/dev/null || true",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.astro": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@vitejs/plugin-react": "6.0.2"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.0",
    "@astrojs/react": "^6.0.0",
    "@lucide/astro": "^1.21.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "hono": "^4.12.27",
    "hono-rate-limiter": "^0.5.3",
    "lucide-react": "^1.21.0",
    "nodemailer": "^9.0.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-google-recaptcha": "^3.1.0",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/ts-plugin": "^1.10.9",
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "@types/react-google-recaptcha": "^2.1.9",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "astro-eslint-parser": "^2.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-doctor": "^0.5.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-unicorn": "^69.0.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.14.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.17.0"
  }
}
