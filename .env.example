# ─── Required ──────────────────────────────────────────────
# Gmail credentials for sending booking/contact/newsletter emails
GMAIL_USER=
GMAIL_PASS=

# ─── Optional ──────────────────────────────────────────────
# Separate recipient email (defaults to GMAIL_USER if not set)
MAIL_TO=

# reCAPTCHA v2 secret key for form protection
# Get yours at: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=

# reCAPTCHA v2 site key (used in client-side forms)
# Must match the site key used in reCAPTCHA components
PUBLIC_RECAPTCHA_SITE_KEY=
